    "dependencies": {
        "canopy/core": "1.0.0 <= v < 2.0.0",
        "canopy/html": "1.0.0 <= v < 2.0.0",
        "canopy/json": "1.0.0 <= v < 2.0.0",
        "canopy/virtual-dom": "1.0.0 <= v < 2.0.0",
        "canopy/url": "1.0.0 <= v < 2.0.0",
        "canopy/svg": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "canopy/test": "1.0.0 <= v < 3.0.0"
    }
