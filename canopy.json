    "name": "canopy/ssr",
    "summary": "Server-side rendering, hydration, meta tags, static site generation, and islands architecture",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "Ssr",
        "Ssr.Render",
        "Ssr.Meta",
